local TweenService = game:GetService("TweenService")
local player = game.Players.LocalPlayer

-- Create ScreenGui and parent it to PlayerGui
local screenGui = Instance.new("ScreenGui", player:WaitForChild("PlayerGui"))

-- Create Frame
local frame = Instance.new("Frame", screenGui)
frame.Size = UDim2.new(0.5, 0, 0.5, 0)
frame.Position = UDim2.new(0.5, 0, 0.5, 0) -- Start off-screen
frame.BackgroundColor3 = Color3.fromRGB(50, 50, 50)

-- Create UICorner for rounded corners
local corner = Instance.new("UICorner", frame)

-- Create Button
local button = Instance.new("TextButton", frame)
button.Size = UDim2.new(0.5, 0, 0.2, 0)
button.Position = UDim2.new(0.25, 0, 0.4, 0)
button.Text = "Click Me!"
button.BackgroundColor3 = Color3.fromRGB(0, 170, 0)

-- Tweening to make the frame appear
local tweenInfo = TweenInfo.new(0.5, Enum.EasingStyle.Back, Enum.EasingDirection.Out)
local goal = { Position = UDim2.new(0.25, 0, 0.25, 0) } -- Move to center

local tween = TweenService:Create(frame, tweenInfo, goal)
tween:Play()

-- Button click event
button.MouseButton1Click:Connect(function()
    print("Button clicked!")
end)

-- Version information (optional)
local version = "0.0.1"
local changeLog = {
    ["0.0.1"] = "Initial release with basic UI and a clickable button."
}

print("Script has started successfully!")

local function showVersionInfo()
    print("Current Version: " .. version)
    print("Change Log:")
    for ver, log in pairs(changeLog) do
        print(ver .. ": " .. log)
    end
end

showVersionInfo()
